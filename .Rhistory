png('./FIGURES/mean_precipitation.png',height=15000,width=17000,res=1200)
ggplot()+
geom_point(data=master_mean,aes(years_until_disoccupation,climate_value,color=climate_value),alpha=0.1,shape=21, fill=NA,size=2,stroke=1.25)+
scale_color_gradientn(colors=c("#bb3e03","#ca6702","#ee9b00","#ffe6a750","#94d2bd","#0a9396","#005f73"), rescaler = ~ scales::rescale_mid(.x, mid = 375),
name = NULL)+
geom_smooth(data=master_mean,aes(years_until_disoccupation,climate_value),method="lm",se=F,color="grey20")+
geom_point(data=highest_precip,aes(years_until_disoccupation,climate_value),alpha=0.1,color="#005f73",shape=21, fill=NA,size=2,stroke=1.25)+
geom_point(data=lowest_precip,aes(years_until_disoccupation,climate_value),alpha=0.1,color="#bb3e03",shape=21, fill=NA,size=2,stroke=1.25)+
labs(x="Years before Resettlement",
y="Precipitation (mm)",
title=NULL)+
theme_minimal()
dev.off()
highest_precip_change <- change_mean%>%
