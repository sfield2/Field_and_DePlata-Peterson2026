#master_output <- read.csv("./OUTPUT/master_output.csv")
master_mean <- subset(master_output, variable == "mean_precipitation")%>%
subset(., years_until_disoccupation <=400)
master_std <- subset(master_output, variable == "std_precipitation")%>%
subset(., years_until_disoccupation <=400)
change_mean <- subset(master_output, variable == "mean_precipitation_change")%>%
subset(., years_until_disoccupation <=400)
change_std <- subset(master_output, variable == "std_precipitation_change")%>%
subset(., years_until_disoccupation <=400)
m_test <- cor.test(master_mean$years_until_disoccupation, master_mean$climate_value)
std_test <- cor.test(master_std$years_until_disoccupation, master_std$climate_value)
m_change_test <- cor.test(change_mean$years_until_disoccupation, change_mean$climate_value)
std_change_test <- cor.test(change_std$years_until_disoccupation, change_std$climate_value)
print("The correlation for Mean Precipitation is:")
print(m_test$estimate)
print(m_test$p.value)
print("The correlation for Std Precipitation is:")
print(std_test$estimate)
print(std_test$p.value)
print("The correlation for Mean Precipitation Change is:")
print(m_change_test$estimate)
print(m_change_test$p.value)
print("The correlation for Std Precipitation Change is:")
print(std_change_test$estimate)
print(std_change_test$p.value)
